{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.6.2" }
  },
  "routes": [
    { "src": "/api/dashboard-stats", "dest": "/api/index.php" },
    { "src": "/api/token", "dest": "/api/index.php" },
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
